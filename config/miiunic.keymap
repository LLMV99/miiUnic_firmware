#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        Default_layer {
            display-name = "QWERTY";
            bindings = <
&kp TAB    &kp Q  &kp W  &kp E     &kp R           &kp T                            &kp Y      &kp U          &kp I       &kp O    &kp P      &kp ESCAPE
&kp LSHFT  &kp A  &kp S  &kp D     &kp F           &kp G                            &kp H      &kp J          &kp K       &kp L    &kp W      &kp RSHFT
&kp LCTRL  &kp Z  &kp X  &kp C     &kp V           &kp B                            &kp N      &kp M          &kp COMMA   &kp DOT  &kp GRAVE  &kp APOS
                         &kp LALT  &lt 1 LEFT_WIN  &kp SPACE  &kp C_MUTE  &kp C_PP  &lt 2 RET  &kp BACKSPACE  &lt 3 RALT
            >;

            sensor-bindings =
                <&inc_dec_kp C_VOLUME_DOWN C_VOLUME_UP>,
                <&inc_dec_kp PG_DN PG_UP>;
        };

        Num_layer {
            display-name = "Numeric";
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans                  &kp LPAR  &kp N7        &kp N8        &kp N9        &kp SLASH  &kp PLUS
&trans  &trans  &trans  &trans  &trans  &trans                  &kp RPAR  &kp NUMBER_4  &kp N5        &kp NUMBER_6  &kp ASTRK  &kp MINUS
&trans  &trans  &trans  &trans  &trans  &trans                  &trans    &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3  &trans     &trans
                        &trans  &trans  &trans  &trans  &trans  &trans    &trans        &kp N0
            >;
        };

        Symb-Arrows {
            display-name = "Symbols";
            bindings = <
&kp BACKSLASH  &kp SLASH  &kp EXCL  &kp AT     &kp HASH  &kp DOLLAR                  &kp EQUAL  &kp QMARK       &kp UP_ARROW    &kp PG_UP        &trans  &trans
&kp CARET      &trans     &kp AMPS  &kp ASTRK  &kp LPAR  &kp RPAR                    &kp PRCNT  &kp LEFT_ARROW  &kp DOWN_ARROW  &kp RIGHT_ARROW  &trans  &trans
&trans         &trans     &kp LBKT  &kp RBKT   &kp LBRC  &kp RBRC                    &kp PIPE   &kp COLON       &kp SEMI        &kp PG_DN        &trans  &trans
                                    &trans     &trans    &kp UNDER   &trans  &trans  &trans     &trans          &trans
            >;
        };

        Functions {
            display-name = "Function";
            bindings = <
&kp F1  &kp F2  &kp F3  &kp F4    &kp F5  &kp F6                  &kp F7  &kp F8   &kp F9    &kp F10  &kp F11  &kp F12
&trans  &trans  &trans  &trans    &trans  &trans                  &trans  &kp INS  &kp HOME  &trans   &trans   &trans
&trans  &trans  &trans  &trans    &trans  &trans                  &trans  &kp DEL  &trans    &trans   &trans   &trans
                        &kp LALT  &trans  &trans  &trans  &trans  &trans  &trans   &trans
            >;
        };
    };
};
